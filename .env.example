# Flight Tracker Rio-California Configuration

# =============================================================================
# API KEYS & CREDENTIALS
# =============================================================================

# Flight APIs
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here
SKYSCANNER_API_KEY=your_skyscanner_api_key_here
GOOGLE_FLIGHTS_API_KEY=your_google_flights_api_key_here

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================

# Email Configuration (Gmail recommended)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password  # Use App Password, not regular password
EMAIL_FROM_NAME=Flight Tracker Rio-California

# Telegram Bot (Create via @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ENABLED=true

# Discord Webhook (Optional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
DISCORD_ENABLED=false

# =============================================================================
# MONITORING CONFIGURATION  
# =============================================================================

# Price Check Settings
PRICE_CHECK_INTERVAL=3600        # Check prices every hour (3600 seconds)
PRICE_CHECK_VARIANCE=300         # Add random variance ±5 minutes to avoid detection
MAX_RETRIES=3                    # Retry failed requests 3 times
REQUEST_DELAY=2                  # Delay between requests (seconds)

# Alert Thresholds
PRICE_DROP_THRESHOLD=0.15        # 15% price drop triggers alert
DEAL_THRESHOLD=0.80              # Prices 20% below average = deal alert
TARGET_PRICE_ENABLED=true        # Enable target price alerts
MIN_PRICE_CHANGE=50              # Minimum R$ change to trigger alert

# =============================================================================
# ROUTE CONFIGURATION
# =============================================================================

# Default Trip Parameters
TRIP_DURATION_DAYS=6             # Fixed 6-day trips
PASSENGER_COUNT=1                # Number of passengers
CABIN_CLASS=economy              # economy, business, first
FLEXIBLE_DATES=true              # Search ±3 days from target date
SEARCH_WINDOW_DAYS=90            # Look ahead 90 days for departure dates

# Airport Codes
RIO_AIRPORTS=GIG,SDU             # Galeão, Santos Dumont
CALIFORNIA_AIRPORTS=LAX,SFO      # Los Angeles, San Francisco

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite Database
DATABASE_PATH=data/flight_prices.db
BACKUP_DATABASE=true
BACKUP_INTERVAL_HOURS=24
MAX_BACKUP_FILES=30

# Data Retention
KEEP_PRICE_HISTORY_DAYS=365      # Keep 1 year of price data
CLEANUP_INTERVAL_HOURS=168       # Cleanup weekly (168 hours)

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Settings
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
LOG_FILE=data/flight_tracker.log
LOG_MAX_SIZE_MB=50               # Rotate logs at 50MB
LOG_BACKUP_COUNT=5               # Keep 5 backup log files

# Debug Settings
VERBOSE_LOGGING=false            # Extra detailed logs
SAVE_SCRAPED_HTML=false          # Save HTML for debugging (dev only)
ENABLE_PROFILING=false           # Performance profiling (dev only)

# =============================================================================
# SCRAPING CONFIGURATION
# =============================================================================

# Web Scraping Settings
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36
SELENIUM_HEADLESS=true           # Run browser in headless mode
SELENIUM_TIMEOUT=30              # Page load timeout (seconds)
SELENIUM_IMPLICIT_WAIT=10        # Element wait timeout (seconds)

# Rate Limiting
REQUESTS_PER_MINUTE=20           # Max requests per minute per source
COOL_DOWN_AFTER_ERROR=300        # Wait 5 minutes after errors
RESPECT_ROBOTS_TXT=true          # Respect robots.txt files

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Environment
ENVIRONMENT=development          # development, production
DEBUG_MODE=true
TESTING_MODE=false

# Development Features
MOCK_API_RESPONSES=false         # Use mock data instead of real APIs
DRY_RUN_NOTIFICATIONS=false      # Log notifications instead of sending
CACHE_API_RESPONSES=false        # Cache API responses for development

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================

# Railway/Heroku Configuration
PORT=8000                        # API port (if web interface enabled)
WEB_INTERFACE_ENABLED=false      # Enable web dashboard
API_ENABLED=false                # Enable REST API endpoints

# GitHub Actions
GITHUB_ACTIONS_ENABLED=true      # Enable automated runs via GitHub Actions
COMMIT_PRICE_DATA=false          # Commit price data to git (not recommended for large datasets)
ACTIONS_SCHEDULE=0 */3 * * *     # Run every 3 hours via cron

# =============================================================================
# ADVANCED FEATURES
# =============================================================================

# Machine Learning
ENABLE_PRICE_PREDICTIONS=false   # ML-based price predictions (requires training data)
PREDICTION_MODEL_PATH=models/    # Path to store ML models
MIN_TRAINING_DATA_POINTS=1000    # Minimum data points before enabling predictions

# Performance
ASYNC_REQUESTS=true              # Use async HTTP requests
MAX_CONCURRENT_REQUESTS=5        # Maximum parallel requests
ENABLE_CACHING=true              # Cache frequent requests
CACHE_TTL_SECONDS=1800           # Cache timeout (30 minutes)

# Experimental
ENABLE_PROXY_ROTATION=false      # Rotate proxies to avoid blocking
PROXY_LIST_URL=                  # URL to proxy list (if using rotation)
ENABLE_CAPTCHA_SOLVING=false     # Auto-solve CAPTCHAs (paid service)